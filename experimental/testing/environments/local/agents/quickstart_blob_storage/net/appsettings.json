{
  "TokenValidation": {
    "Audiences": [ "${{ APP_ID }}" ],
    "TenantId": "${{ TENANT_ID }}"
  },
  "Connections": {
    "ServiceConnection": {
      "Settings": {
        "AuthType": "${{ AUTH_TYPE }}",
        "AuthorityEndpoint": "https://login.microsoftonline.com/${{ TENANT_ID }}",
        "ClientId": "${{ APP_ID }}",
        "ClientSecret": "${{ CLIENT_SECRET }}",
        "FederatedClientId": "${{ UMI_CLIENT_ID }}",
        "Scopes": [ "https://api.botframework.com/.default" ]
      }
    }
  },
  "ConnectionsMap": [
    {
      "ServiceUrl": "*",
      "Connection": "ServiceConnection"
    }
  ],
  "Storage": {
    "BlobStorageAccountUrl": "${{ STORAGE_ACCOUNT_URL }}",
    "ContainerName": "${{ BLOB_CONTAINER_NAME }}"
  }
}

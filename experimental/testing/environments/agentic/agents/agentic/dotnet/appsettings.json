{
  "TokenValidation": {
    "Enabled": true,
    "Audiences": [
      "${{ APP_ID }}",
      "${{ AGENT_BLUEPRINT_ID }}"
    ],
    "TenantId": "${{ TENANT_ID }}"
  },

  "AgentApplication": {
    "StartTypingTimer": true,
    "RemoveRecipientMention": false,
    "NormalizeMentions": false,
    "UserAuthorization": {
      "AutoSignin": false,
      "Handlers": {
        "agentic": {
          "Type": "AgenticUserAuthorization",
          "Settings": {
            "Scopes": [
              "https://graph.microsoft.com/.default"
            ]
          }
        },
        "me": {
          "Type": "AzureBotUserAuthorization",
          "Settings": {
            "AzureBotOAuthConnectionName": "agentic",
            "OBOConnectionName": "BotConnection",
            "EnableSso": false
          }
        },
        "bot": {
          "Type": "AzureBotUserAuthorization",
          "Settings": {
            "AzureBotOAuthConnectionName": "sso"
          }
        }
      }
    }
  },

  "Connections": {
    "BlueprintConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/${{ TENANT_ID }}",
        "ClientId": "${{ AGENT_BLUEPRINT_ID }}",
        "ClientSecret": "${{ AGENT_BLUEPRINT_SECRET }}",
        "Scopes": [
          "5a807f24-c9de-44ee-a3a7-329e88a00ffc/.default"
        ]
      }
    },
    "BotConnection": {
      "Settings": {
        "AuthType": "ClientSecret",
        "AuthorityEndpoint": "https://login.microsoftonline.com/${{ TENANT_ID }}",
        "ClientId": "${{ APP_ID }}",
        "ClientSecret": "${{ CLIENT_SECRET }}",
        "Scopes": [
          "https://api.botframework.com/.default"
        ]
      }
    }
  },
  "ConnectionsMap": [
    {
      "Audience": "${{ APP_ID }}",
      "Connection": "BotConnection"
    },
    {
      "ServiceUrl": "*",
      "Connection": "BlueprintConnection"
    }
  ],

  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.Agents": "Debug",
      "Microsoft.AspNetCore": "Debug"
    }
  }
}
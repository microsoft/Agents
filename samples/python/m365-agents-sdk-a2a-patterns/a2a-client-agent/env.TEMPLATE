# A2A Client Agent SDK Auth (leave empty for anonymous/local mode)
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTID=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__CLIENTSECRET=
CONNECTIONS__SERVICE_CONNECTION__SETTINGS__TENANTID=

# A2A Remote Agent (ADK Brand Search Optimization Agent)
A2A_AGENT_URL=http://localhost:8080

# Webhook receiver for push notifications (this agent's own URL)
AGENT_HOST=localhost
AGENT_PORT=3978

# Azure AI Foundry (LLM Orchestration)
# Your Azure AI Services endpoint (NOT the project endpoint)
# e.g., https://your-resource.services.ai.azure.com
AZURE_AI_FOUNDRY_ENDPOINT=

# API key for Azure AI Services
AZURE_AI_FOUNDRY_API_KEY=

# Model deployment name in your Azure AI project
AZURE_AI_FOUNDRY_MODEL=gpt-4o-mini
